#!/usr/bin/env sh
# Pre-commit: RuboCop + RSpec, host-side. Our postgres is on host port 5433.
# Skips RSpec (never blocks) when our DB is down; CI is the backstop.

if [ -t 1 ]; then
  B='\033[1m'; D='\033[2m'; R='\033[31m'; G='\033[32m'; Y='\033[33m'; C='\033[36m'; X='\033[0m'
else
  B=''; D=''; R=''; G=''; Y=''; C=''; X=''
fi
OUT="$(mktemp)"

# run <label> <cmd...> — spinner while it runs, ✓/✗ + elapsed, output only on failure.
run() {
  label="$1"; shift
  "$@" >"$OUT" 2>&1 &
  pid=$!
  start="$(date +%s)"
  while kill -0 "$pid" 2>/dev/null; do
    for frame in ⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏; do
      printf "\r  ${C}%s${X} %s${D}…${X} " "$frame" "$label"
      kill -0 "$pid" 2>/dev/null || break
      sleep 0.08
    done
  done
  wait "$pid"; status=$?
  secs="$(( $(date +%s) - start ))"
  if [ "$status" -eq 0 ]; then
    printf "\r  ${G}✓${X} %s ${D}%ss${X}      \n" "$label" "$secs"
  else
    printf "\r  ${R}✗${X} %s ${D}%ss${X}      \n" "$label" "$secs"
    sed 's/^/    /' "$OUT"
  fi
  return "$status"
}

printf "${B}${C}▌ pre-commit${X} ${D}· rubocop · rspec${X}\n"

run rubocop bundle exec rubocop --format simple || { rm -f "$OUT"; exit 1; }

if ! pg_isready -h localhost -p 5433 -q 2>/dev/null; then
  printf "  ${Y}◦${X} rspec ${D}skipped — our postgres is down (bin/docker-up); CI covers it${X}\n"
  rm -f "$OUT"; exit 0
fi

export DATABASE_HOST=localhost DATABASE_PORT=5433
run rspec bundle exec rspec --format progress || { rm -f "$OUT"; exit 1; }

rm -f "$OUT"
printf "${G}${B}✓ all clear${X}\n"
