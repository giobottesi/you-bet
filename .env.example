# You-Bet Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# --- Database (Docker Compose sets these automatically) ---
DATABASE_HOST=postgres
DATABASE_USERNAME=you_bet
DATABASE_PASSWORD=you_bet
DATABASE_PORT=5432

# --- Rails ---
RAILS_ENV=development
RAILS_LOG_LEVEL=debug
# SECRET_KEY_BASE=        # Required in production. Generate with: rails secret
# RAILS_MASTER_KEY=       # Required in production. From config/master.key

# --- Rate limiting (Rack::Attack — safe defaults, tuneable without redeploy) ---
# SIMULATION_THROTTLE_LIMIT=10   # POST /simulations, per IP
# SIMULATION_THROTTLE_PERIOD=60
# GENERAL_THROTTLE_LIMIT=300     # all paths except /assets, /up
# GENERAL_THROTTLE_PERIOD=300
# FAIL2BAN_ENABLED=              # set (any value) to enable exploit-probe blocklist; off by default
# FAIL2BAN_MAXRETRY=3
# FAIL2BAN_FINDTIME=600
# FAIL2BAN_BANTIME=3600

# --- Optional ---
# SENTRY_DSN=             # Exception tracking
