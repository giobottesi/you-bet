<% content_for :title, "You-Bet — #{t('privacy.title')}" %>

<section class="py-8">
  <h1 class="mb-4 text-[2rem]/[1.2] font-extrabold text-text [text-shadow:3px_3px_0_var(--color-coral)] sm:text-[2.5rem]"><%= t("privacy.heading") %></h1>
  <p class="text-base text-muted"><%= t("privacy.intro") %></p>
</section>

<section aria-label="<%= t('privacy.collected_label') %>">
  <ul class="flex flex-col gap-4">
    <% @collected_data_keys.each do |key| %>
      <li class="bg-surface [background-image:var(--paper-grain)] border-[3px] border-border p-5 shadow-[6px_6px_0_var(--shadow-25)]">
        <h2 class="text-[1.15rem] font-extrabold text-text"><%= t("privacy.collected.#{key}.name") %></h2>
        <p class="mt-2 text-[0.8rem] font-bold uppercase tracking-[0.06em] text-muted"><%= t("privacy.purpose_label") %></p>
        <p class="text-base text-text"><%= t("privacy.collected.#{key}.purpose") %></p>
        <p class="mt-2 text-[0.8rem] font-bold uppercase tracking-[0.06em] text-muted"><%= t("privacy.retention_label") %></p>
        <p class="text-base text-text"><%= t("privacy.collected.#{key}.retention") %></p>
      </li>
    <% end %>
  </ul>
</section>

<section class="py-8" aria-label="<%= t('privacy.deletion.heading') %>">
  <h2 class="mb-4 text-[1.5rem] font-extrabold text-text"><%= t("privacy.deletion.heading") %></h2>
  <p class="text-base text-muted"><%= t("privacy.deletion.intro") %></p>
  <ul class="mt-4 flex flex-col gap-4">
    <li class="border-l-[3px] border-border pl-4">
      <p class="text-base text-text"><%= t("privacy.deletion.step_clear_cookie") %></p>
    </li>
    <li class="border-l-[3px] border-border pl-4">
      <p class="text-base text-text"><%= t("privacy.deletion.step_no_profile") %></p>
    </li>
  </ul>
  <p class="mt-4 text-base text-muted"><%= t("privacy.deletion.contact_html", repo_link: link_to(t("privacy.deletion.contact_repo_label"), ContentController::REPOSITORY_URL, class: "underline", target: "_blank", rel: "noopener")) %></p>
</section>

<section class="py-8" aria-label="<%= t('privacy.references.heading') %>">
  <h2 class="mb-4 text-[1.5rem] font-extrabold text-text"><%= t("privacy.references.heading") %></h2>
  <ul class="flex flex-col gap-2">
    <% @reference_links.each do |key, url| %>
      <li>
        <%= link_to t("privacy.references.#{key}"), url, class: "text-base text-text underline", target: "_blank", rel: "noopener" %>
      </li>
    <% end %>
  </ul>
</section>
