<% content_for :title, t("simulations.new.title") %>

<section class="py-8">
  <h1 class="mb-4 text-[2rem]/[1.2] font-extrabold text-text sm:text-[2.5rem]"><span class="brand-heading" style="--mark: var(--color-coral)"><%= t("simulations.new.heading") %></span></h1>
  <p class="text-base text-muted"><%= t("simulations.new.intro") %></p>
</section>

<section class="bg-surface [background-image:var(--rough-paper)] [background-blend-mode:soft-light] [background-size:320px_320px] border-[3px] border-border p-6 shadow-[6px_6px_0_var(--shadow-25)]" aria-label="Simulation form">
  <%= form_with model: @simulation, url: simulations_path, method: :post, data: { turbo: false } do |form| %>
    <%= render "bet_type_picker", form: form %>
    <%= render "weekly_amount", form: form %>
    <%= render "timeframe_slider", form: form %>
    <%= form.button t("simulations.new.submit"), type: "submit", class: "cta" %>
  <% end %>
</section>
