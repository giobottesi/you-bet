<%# FE-09 — real support resources, always visible on results. Unified result-card shell, whimsy OFF
    (delicate content): one calm cyan accent, no washi, no color cycling. %>
<section class="result-card mt-10" style="--card-accent: var(--color-cyan)" aria-labelledby="help-resources-heading">
  <details class="group">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-3">
      <h2 id="help-resources-heading" class="text-[1.5rem] font-extrabold uppercase tracking-[0.04em] text-text"><%= t("simulations.results.help.heading") %></h2>
      <span aria-hidden="true" class="flex-none text-[1.6rem] font-black leading-none text-cyan-ink transition-transform group-open:rotate-45">+</span>
    </summary>
    <p class="mt-3 text-base text-muted"><%= t("simulations.results.help.intro") %></p>

    <ul class="mt-5 flex flex-col gap-4">
    <% help_resources.each do |resource| %>
      <li class="border-l-[4px] border-cyan-ink bg-bg/60 p-4">
        <h3 class="text-[1.05rem] font-extrabold text-text">
          <%= link_to "#{t("simulations.results.help.resources.#{resource[:key]}.name")} ↗",
                      resource[:url],
                      class: "text-cyan-ink underline",
                      target: "_blank", rel: "noopener" %>
        </h3>
        <p class="mt-1 text-base text-text"><%= t("simulations.results.help.resources.#{resource[:key]}.description") %></p>
        <% if resource[:phone] %>
          <p class="mt-1 text-base text-text">
            <%= t("simulations.results.help.call_label") %>
            <%= link_to resource[:phone], "tel:#{resource[:phone]}", class: "font-bold text-cyan-ink underline" %>
          </p>
        <% end %>
      </li>
    <% end %>
    </ul>
  </details>
</section>
