<%# FE-07 — the payoff: what the lost money could have bought, and what it would have grown to in poupança. %>
<section class="mt-10" aria-labelledby="opportunity-heading">
  <h2 id="opportunity-heading" class="text-[1.5rem] font-extrabold text-text text-marker-effect" style="--mark: var(--color-cyan)">
    <%= t("simulations.results.opportunity.heading") %>
  </h2>

  <ul class="mt-5 grid grid-cols-2 gap-4">
    <% @item_comparisons.each_with_index do |comparison, index| %>
      <li class="result-card flex flex-col justify-end" style="<%= notepad_accent_style(index, "--card-accent") %>">
        <p class="text-[1.75rem]/[1] font-extrabold text-text"><%= comparison[:quantity] %></p>
        <p class="mt-1 text-base font-bold text-text"><%= comparison_label(comparison) %></p>
      </li>
    <% end %>
  </ul>

  <% if @poupanca_comparison %>
    <div class="result-card mt-4 flex flex-col gap-1" style="--card-accent: var(--color-green)">
      <p class="text-[0.8rem] font-bold uppercase tracking-[0.06em] text-green-ink"><%= t("simulations.results.opportunity.poupanca_label") %></p>
      <p class="text-[2rem]/[1.1] font-extrabold text-green-ink"><%= reais_label(@poupanca_comparison[:balance_cents]) %></p>
      <p class="text-base text-text"><%= t("simulations.results.opportunity.poupanca_note") %></p>
    </div>
  <% end %>
</section>
