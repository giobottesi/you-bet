<% content_for :title, t("simulations.results.title") %>

<div class="page mx-auto w-full max-w-3xl p-5 sm:p-8" data-simulation-uuid="<%= @simulation.to_param %>">
  <h1 class="text-[2rem]/[1.2] font-extrabold text-text"><%= t("simulations.results.heading") %></h1>
  <p class="mt-3 text-base text-muted">
    <%= t("simulations.results.summary",
          amount: weekly_amount_label(@simulation.weekly_amount_cents),
          timeframe: timeframe_label(@simulation.timeframe_weeks)) %>
  </p>

  <% weeks = @simulation.timeframe_weeks %>
  <ul class="mt-6 flex flex-col gap-8">
    <% @bet_type_results.each_with_index do |(bet_type, simulation_result), index| %>
      <% next unless simulation_result.result_by_timeframe(weeks) %>
      <li class="notepad" style="<%= notepad_accent_style(index, "--bar") %>; <%= notepad_accent_style(index, "--label-accent", ink: true) %>">
        <div class="notepad__bar"></div>
        <div class="notepad__body">
          <h2 class="text-[1.15rem]/[var(--note-gap)] font-extrabold text-text"><%= bet_type.display_name %></h2>
          <p class="text-[2rem]/[calc(var(--note-gap)*2)] font-extrabold text-loss"><%= reais_label(simulation_result.loss_cents(weeks)) %></p>
          <p class="text-base/[var(--note-gap)] text-muted">
            <%= t("simulations.results.loss_share",
                  percentage: loss_percentage_label(simulation_result.loss_fraction(weeks))) %>
          </p>
        </div>
      </li>
    <% end %>
  </ul>

  <%= render "help_resources" %>
</div>
