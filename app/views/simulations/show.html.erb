<% content_for :title, "You-Bet — Your results" %>

<%# FE-05 stub — permalink target for a persisted simulation. Full results page lands in FE-06+. %>
<div class="page mx-auto w-full max-w-3xl p-5 sm:p-8" data-simulation-uuid="<%= @simulation.to_param %>">
  <h1 class="text-[2rem]/[1.2] font-extrabold text-text">Crunching your numbers…</h1>
  <p class="mt-4 text-base text-muted">
    Results for <%= @simulation.bet_type_keys.size %> bet type(s) at
    <%= weekly_amount_label(@simulation.weekly_amount_cents) %>/week are on the way.
  </p>
</div>
