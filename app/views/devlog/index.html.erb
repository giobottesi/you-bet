<% content_for :title, "You-Bet — #{t('devlog.title')}" %>

<section class="py-8">
  <h1 class="mb-4 text-[2rem]/[1.2] font-extrabold text-text [text-shadow:3px_3px_0_var(--color-coral)] sm:text-[2.5rem]"><%= t("devlog.heading") %></h1>
  <p class="text-base text-muted"><%= t("devlog.intro") %></p>
  <p class="mt-3 border-l-4 border-purple bg-surface p-3 text-sm italic text-muted"><%= t("devlog.ai_note") %></p>
</section>

<section aria-label="<%= t('devlog.title') %>">
  <ol class="flex flex-col gap-4">
    <% @entries.each_with_index do |entry, index| %>
      <li class="bg-surface [background-image:var(--paper-grain)] border-[3px] border-border p-5 shadow-[6px_6px_0_var(--shadow-25)]">
        <details<%= " open".html_safe if index.zero? %>>
          <summary class="cursor-pointer text-lg font-extrabold text-text marker:text-coral"><%= entry.title %></summary>
          <div class="mt-4 flex flex-col gap-3">
            <% entry.sections.each do |section| %>
              <% if section.heading %>
                <details class="devlog-section">
                  <summary class="cursor-pointer font-bold text-text marker:text-purple"><%= section.heading %></summary>
                  <div class="markdown-body mt-2"><%= render_markdown(section.body) %></div>
                </details>
              <% elsif section.body.present? %>
                <div class="markdown-body"><%= render_markdown(section.body) %></div>
              <% end %>
            <% end %>
          </div>
        </details>
      </li>
    <% end %>
  </ol>
</section>
