<% content_for :title, "You-Bet — #{t('about.title')}" %>

<section class="py-8">
  <h1 class="mb-4 text-[2rem]/[1.2] font-extrabold text-text [text-shadow:3px_3px_0_var(--color-coral)] sm:text-[2.5rem]"><%= t("about.heading") %></h1>
  <p class="text-base text-muted"><%= t("about.intro") %></p>
</section>

<%# AI declaration — competition-required + factual. This section ships complete. %>
<section class="py-4" aria-label="<%= t('about.ai.heading') %>">
  <h2 class="mb-4 text-[1.5rem] font-extrabold text-text [text-shadow:2px_2px_0_var(--color-purple)]"><%= t("about.ai.heading") %></h2>
  <div class="bg-surface [background-image:var(--paper-grain)] border-[3px] border-border p-5 shadow-[6px_6px_0_rgba(0,0,0,0.25)]">
    <p class="text-base text-text"><%= t("about.ai.intro") %></p>
    <p class="mt-3 text-[0.8rem] font-bold uppercase tracking-[0.06em] text-muted"><%= t("about.ai.roles_label") %></p>
    <ul class="mt-2 flex flex-col gap-2">
      <% t("about.ai.roles").each do |role| %>
        <li class="border-l-[3px] border-purple pl-4 text-base text-text"><%= role %></li>
      <% end %>
    </ul>
    <p class="mt-4 text-base text-text"><%= t("about.ai.betina") %></p>
  </div>
</section>

<%# GIO PLACEHOLDER — the developer-story sections below are stubs for Gio to fill in her own voice.
    Headings are drafted so the page has shape; every body is placeholder prose (see about.story.* in the locales). %>
<section class="py-4" aria-label="<%= t('about.story.heading') %>">
  <h2 class="mb-4 text-[1.5rem] font-extrabold text-text [text-shadow:2px_2px_0_var(--color-cyan)]"><%= t("about.story.heading") %></h2>
  <div class="flex flex-col gap-4">
    <% @story_sections.each do |section| %>
      <div class="border-[3px] border-dashed border-border p-5">
        <div class="mb-2 flex items-center justify-between gap-3">
          <h3 class="text-[1.15rem] font-extrabold text-text"><%= t("about.story.#{section}.heading") %></h3>
          <span class="flex-none rounded-sm bg-yellow px-2 py-0.5 text-[0.7rem] font-bold uppercase tracking-[0.06em] text-text"><%= t("about.placeholder_tag") %></span>
        </div>
        <p class="text-base italic text-muted"><%= t("about.story.#{section}.body") %></p>
      </div>
    <% end %>
  </div>
</section>

<%# Brand touchstone — Gatinho, the friendly counterpoint to Tigrinho (text-art placeholder until Gio's illustration ships, per DESIGN.md). %>
<section class="py-4" aria-label="<%= t('about.gatinho.heading') %>">
  <div class="flex items-center gap-5 bg-surface [background-image:var(--paper-grain)] border-[3px] border-border p-5 shadow-[6px_6px_0_rgba(0,0,0,0.25)]">
    <pre aria-hidden="true" class="flex-none text-[0.7rem]/[1.1] font-bold text-coral">
 /\_/\
( o.o )
 =^.^=</pre>
    <div>
      <h2 class="text-[1.15rem] font-extrabold text-text"><%= t("about.gatinho.heading") %></h2>
      <p class="mt-1 text-base text-muted"><%= t("about.gatinho.body") %></p>
    </div>
  </div>
</section>

<%# Outbound links — public repo, the in-the-open devlog, the live site. %>
<section class="py-4" aria-label="<%= t('about.links.heading') %>">
  <h2 class="mb-4 text-[1.5rem] font-extrabold text-text"><%= t("about.links.heading") %></h2>
  <ul class="flex flex-col gap-3">
    <li><%= link_to t("about.links.repository"), @repository_url, class: "font-bold underline", target: "_blank", rel: "noopener" %></li>
    <li><%= link_to t("about.links.devlog"), devlog_path, class: "font-bold underline" %></li>
    <li><%= link_to t("about.links.sources"), sources_path, class: "font-bold underline" %></li>
  </ul>
</section>

<%# FAQ at the end — Betina's genuine open questions to Gio. Questions are written; every answer is Gio's to fill. %>
<section class="py-8" aria-label="<%= t('about.faq.heading') %>">
  <h2 class="mb-2 text-[1.5rem] font-extrabold text-text [text-shadow:2px_2px_0_var(--color-coral)]"><%= t("about.faq.heading") %></h2>
  <p class="mb-4 text-base text-muted"><%= t("about.faq.intro") %></p>
  <ul class="flex flex-col gap-4">
    <% @faq_questions.each do |question| %>
      <li class="bg-surface [background-image:var(--paper-grain)] border-[3px] border-border p-5 shadow-[6px_6px_0_rgba(0,0,0,0.25)]">
        <p class="text-[1.05rem] font-extrabold text-text"><%= t("about.faq.#{question}.question") %></p>
        <div class="mt-3 border-[3px] border-dashed border-border p-4">
          <span class="mb-1 inline-block rounded-sm bg-yellow px-2 py-0.5 text-[0.7rem] font-bold uppercase tracking-[0.06em] text-text"><%= t("about.placeholder_tag") %></span>
          <p class="text-base italic text-muted"><%= t("about.faq.#{question}.answer") %></p>
        </div>
      </li>
    <% end %>
  </ul>
</section>
