<% content_for :title, "You-Bet — #{t('devlog.title')}" %>

<section class="py-8">
  <h1 class="mb-4 text-[2rem]/[1.2] font-extrabold text-text [text-shadow:3px_3px_0_var(--color-coral)] sm:text-[2.5rem]"><%= t("devlog.heading") %></h1>
  <p class="text-base text-muted"><%= t("devlog.intro") %></p>
</section>

<section aria-label="<%= t('devlog.title') %>">
  <ol class="flex flex-col gap-4">
    <% @entries.each do |entry| %>
      <li class="bg-surface [background-image:var(--paper-grain)] border-[3px] border-border p-5 shadow-[6px_6px_0_rgba(0,0,0,0.25)]">
        <%= simple_format(entry.body, {}, wrapper_tag: "div") %>
      </li>
    <% end %>
  </ol>
</section>
