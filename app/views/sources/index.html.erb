<% content_for :title, "You-Bet — #{t('sources.title')}" %>

<section class="py-8">
  <h1 class="mb-4 text-[2rem]/[1.2] font-extrabold text-text [text-shadow:3px_3px_0_var(--color-coral)] sm:text-[2.5rem]"><%= t("sources.heading") %></h1>
  <p class="text-base text-muted"><%= t("sources.intro") %></p>
</section>

<section aria-label="<%= t('sources.list_label') %>">
  <ul class="flex flex-col gap-8">
    <% @data_sources.each_with_index do |source, index| %>
      <li class="notepad" style="<%= notepad_accent_style(index, "--bar") %>">
        <div class="notepad__bar"></div>
        <div class="notepad__body">
          <h2 class="text-[1.15rem]/[var(--note-gap)] font-extrabold text-text"><%= source[:name] %></h2>
          <p class="text-[0.8rem]/[var(--note-gap)] font-bold uppercase tracking-[0.06em] text-muted"><%= t("sources.provides_label") %></p>
          <p class="text-base/[var(--note-gap)] text-text"><%= t("sources.data.#{source[:key]}.provides") %></p>
          <p class="text-[0.8rem]/[var(--note-gap)] font-bold uppercase tracking-[0.06em] text-muted"><%= t("sources.figures_label") %></p>
          <p class="text-base/[var(--note-gap)] text-text"><%= t("sources.data.#{source[:key]}.figures") %></p>
          <p class="text-base/[var(--note-gap)]"><%= link_to t("sources.source_link"), source[:url], class: "font-bold underline", target: "_blank", rel: "noopener" %></p>
        </div>
      </li>
    <% end %>
  </ul>
</section>

<section class="py-8" aria-label="<%= t('sources.methodology_heading') %>">
  <div class="note-poster">
    <h2 class="mb-4 text-[1.5rem] font-extrabold uppercase tracking-[0.04em] text-text"><%= t("sources.methodology_heading") %></h2>
    <% @methodological_notes.each_with_index do |note, index| %>
      <div class="note-card" style="<%= notepad_accent_style(index, "--dash") %>">
        <span class="washi <%= index.even? ? "washi--left" : "washi--right" %>" style="<%= notepad_accent_style(index + 1, "--tape") %>"></span>
        <p class="font-bold text-text"><%= t("sources.notes.#{note[:key]}.subject") %></p>
        <p class="text-base text-muted"><%= t("sources.notes.#{note[:key]}.body") %></p>
        <% if note[:citations] %>
          <p class="mt-2 text-[0.85rem] text-muted">
            <span class="font-bold uppercase tracking-[0.04em]"><%= t("sources.cited_label") %></span>
            <%= note_citation_links(note) %>
          </p>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
