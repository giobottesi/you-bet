<% content_for :title, "You-Bet — #{t('sources.title')}" %>

<section class="py-8">
  <h1 class="mb-4 text-[2rem]/[1.2] font-extrabold text-text [text-shadow:3px_3px_0_var(--color-coral)] sm:text-[2.5rem]"><%= t("sources.heading") %></h1>
  <p class="text-base text-muted"><%= t("sources.intro") %></p>
</section>

<section aria-label="<%= t('sources.list_label') %>">
  <ul class="flex flex-col gap-4">
    <% @data_sources.each do |source| %>
      <li class="bg-surface [background-image:var(--paper-grain)] border-[3px] border-border p-5 shadow-[6px_6px_0_rgba(0,0,0,0.25)]">
        <h2 class="text-[1.15rem] font-extrabold text-text"><%= source[:name] %></h2>
        <p class="mt-2 text-[0.8rem] font-bold uppercase tracking-[0.06em] text-muted"><%= t("sources.provides_label") %></p>
        <p class="text-base text-text"><%= source[:provides] %></p>
        <p class="mt-2 text-[0.8rem] font-bold uppercase tracking-[0.06em] text-muted"><%= t("sources.figures_label") %></p>
        <p class="text-base text-text"><%= source[:figures] %></p>
      </li>
    <% end %>
  </ul>
</section>

<section class="py-8" aria-label="<%= t('sources.methodology_heading') %>">
  <h2 class="mb-4 text-[1.5rem] font-extrabold text-text"><%= t("sources.methodology_heading") %></h2>
  <ul class="flex flex-col gap-4">
    <% @methodological_notes.each do |note| %>
      <li class="border-l-[3px] border-border pl-4">
        <p class="font-bold text-text"><%= note[:subject] %></p>
        <p class="text-base text-muted"><%= note[:note] %></p>
      </li>
    <% end %>
  </ul>
</section>
