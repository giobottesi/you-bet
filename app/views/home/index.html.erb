<% content_for :title, "You-Bet" %>

<div class="landing">
  <div class="landing__sparkle landing__sparkle--1">✦</div>
  <div class="landing__sparkle landing__sparkle--2">✧</div>
  <div class="landing__sparkle landing__sparkle--3">✦</div>
  <div class="landing__sparkle landing__sparkle--4">✧</div>

  <pre class="landing__cat" aria-hidden="true">
     ✧              ✦
        /\_____/\
       /  o   o  \
      ( ==  ᴥ  == )
       )  \___/  (
      (           )
     ( (  )   (  ) )
    (__(__)___(__)__)
  ✦              ✧
  </pre>

  <img class="landing__logo" src="/you-bet-logo.svg" alt="You-Bet" width="440" height="146">
  <p class="landing__tagline">See what the bet really costs.</p>
  <p class="landing__soon">Coming soon</p>
</div>

<style>
  .landing {
    --bg: #FBF6EC;
    --surface: #EDE9E2;
    --border: #DFC3DA;
    --text: #3B3239;
    --muted: #6E6358;
    --coral-ink: #AA473F;
    --cyan-ink: #377066;
    --green-ink: #367225;
    --purple-ink: #8152AE;
    --yellow: #F4BB5C;
    --yellow-ink: #7F6130;

    position: relative;
    box-sizing: border-box;
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 2rem;
    background: var(--surface);
    border: 3px solid var(--border);
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.25);
    color: var(--text);
    text-align: center;
    font-family: "Libre Franklin", system-ui, sans-serif;
  }

  body { background: #FBF6EC; }

  .landing__cat {
    margin: 0 auto 1.5rem;
    color: var(--coral-ink);
    font-size: 0.95rem;
    line-height: 1.15;
  }

  .landing__logo {
    display: block;
    width: 100%;
    max-width: 440px;
    height: auto;
    margin: 0 auto 0.75rem;
  }

  .landing__tagline {
    margin: 0 0 2rem;
    font-size: 1.125rem;
    color: var(--muted);
  }

  .landing__soon {
    display: inline-block;
    margin: 0;
    padding: 0.4rem 1.1rem;
    background: var(--yellow);
    border: 2px solid #000;
    box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.25);
    color: var(--text);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .landing__sparkle {
    position: absolute;
    font-size: 1.25rem;
  }
  .landing__sparkle--1 { top: 1rem;    left: 1.25rem;  color: var(--cyan-ink); }
  .landing__sparkle--2 { top: 1.5rem;  right: 1.5rem;  color: var(--yellow-ink); }
  .landing__sparkle--3 { bottom: 1.5rem; left: 2rem;   color: var(--purple-ink); }
  .landing__sparkle--4 { bottom: 1rem;  right: 1.75rem; color: var(--coral-ink); }

  @media (max-width: 480px) {
    .landing__logo { max-width: 280px; }
    .landing__cat  { font-size: 0.75rem; }
  }
</style>
